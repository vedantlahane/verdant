{
  "compilerOptions": {
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "moduleResolution": "node",
      "jsx": "react-jsx",
      "baseUrl": ".",
      "paths": {
        "@verdant/*": ["packages/*/src"]
      }
  }
}
